{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Beyond Paste",
  "version": "0.1.0",
  "identifier": "com.beyondpaste.desktop",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "library",
        "title": "Beyond Paste",
        "width": 1320,
        "height": 860,
        "minWidth": 1040,
        "minHeight": 720,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/tray.png"]
  }
}
